#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SCRIPT="$SCRIPT_DIR/analyze_video.py"
RUNTIME_PYTHON=${VIDEO_UNDERSTANDING_PYTHON:-"$HOME/.vibelab-tools/agent-skills/video-understanding/venv/bin/python"}

if [ -x "$RUNTIME_PYTHON" ] && "$RUNTIME_PYTHON" -c 'import sys, argparse, json, subprocess, urllib.parse; assert sys.version_info >= (3, 10)' >/dev/null 2>&1; then
  exec "$RUNTIME_PYTHON" "$SCRIPT" "$@"
fi

for candidate in python3 python python3.14 python3.13 python3.12 python3.11 python3.10 \
  /opt/homebrew/bin/python3.14 /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3.12 \
  /opt/homebrew/bin/python3.11 /opt/homebrew/bin/python3 /usr/local/bin/python3.14 \
  /usr/local/bin/python3.13 /usr/local/bin/python3.12 /usr/local/bin/python3.11 \
  /usr/local/bin/python3 /usr/bin/python3
do
  if command -v "$candidate" >/dev/null 2>&1; then
    resolved=$(command -v "$candidate")
  elif [ -x "$candidate" ]; then
    resolved=$candidate
  else
    continue
  fi

  if "$resolved" -c 'import sys, argparse, json, subprocess, urllib.parse; assert sys.version_info >= (3, 10)' >/dev/null 2>&1; then
    exec "$resolved" "$SCRIPT" "$@"
  fi
done

echo "No suitable Python runtime found. Install Python 3.10+ or run analyze_video.py with a Python 3.10+ interpreter." >&2
exit 1
