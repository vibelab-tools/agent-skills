{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/plugins/relay/scripts/hook-user-prompt.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/plugins/relay/scripts/hook-stop.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
