#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR_PATH="${SCRIPT_DIR}/../assets/code-refactor-tools.jar"

if [[ ! -f "${JAR_PATH}" ]]; then
  echo "code-refactor-tools.jar not found at ${JAR_PATH}" >&2
  exit 127
fi

exec java -jar "${JAR_PATH}" "$@"
